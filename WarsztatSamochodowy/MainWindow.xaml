<Window x:Class="WarsztatSamochodowy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Warsztat samochodowy"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,12">
            <TextBlock Text="Warsztat samochodowy"
                       FontSize="24"
                       FontWeight="Bold"/>
            <TextBlock Text="Zarządzanie pojazdami, zleceniami, klientami i finansami"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <WrapPanel Grid.Row="1"
                   Margin="0,0,0,12">
            <Button Content="Pokaż pojazdy"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="ShowVehicles_Click"/>
            <Button Content="Pokaż zlecenia"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="ShowOrders_Click"/>
            <Button Content="Dodaj zlecenie"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="CreateOrder_Click"/>
            <Button Content="Edytuj zlecenie"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="EditOrder_Click"/>
            <Button Content="Zamknij zlecenie"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="CloseOrder_Click"/>
            <Button Content="Finanse"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="ShowFinance_Click"/>
            <Button Content="Klienci"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="ShowClients_Click"/>
            <Button Content="Dodaj klienta"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="AddClient_Click"/>
            <Button Content="Usługi"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="ShowServices_Click"/>
            <Button Content="Części"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="ShowParts_Click"/>
            <Button Content="Dodaj pojazd"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="AddVehicle_Click"/>
            <Button Content="Wyjście"
                    Margin="0,0,8,8"
                    Padding="12,6"
                    Click="Exit_Click"/>
        </WrapPanel>

        <Border Grid.Row="2"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <DockPanel>
                <TextBlock x:Name="StatusText"
                           DockPanel.Dock="Top"
                           Margin="0,0,0,8"
                           TextWrapping="Wrap"/>
                <DataGrid x:Name="DataGridResults"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          CanUserAddRows="False"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
